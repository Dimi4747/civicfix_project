# Configuration Apache pour Django avec Passenger
PassengerEnabled On
PassengerAppRoot /home/username/civicfix_project
PassengerPython /home/username/virtualenv/civicfix_project/3.11/bin/python3
PassengerAppType wsgi
PassengerStartupFile passenger_wsgi.py

# Rediriger toutes les requêtes vers l'application Django
RewriteEngine On
RewriteBase /
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^(.*)$ passenger_wsgi.py [QSA,L]

# Servir les fichiers statiques directement
<IfModule mod_alias.c>
    Alias /static /home/username/civicfix_project/staticfiles
    Alias /media /home/username/civicfix_project/media
</IfModule>

# Permissions pour les fichiers statiques
<Directory /home/username/civicfix_project/staticfiles>
    Require all granted
</Directory>

<Directory /home/username/civicfix_project/media>
    Require all granted
</Directory>

# Sécurité - Empêcher l'accès aux fichiers sensibles
<FilesMatch "\.(py|pyc|pyo|db|sqlite3|env|git|gitignore)$">
    Require all denied
</FilesMatch>

# Compression GZIP
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# Cache des fichiers statiques
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
</IfModule>
